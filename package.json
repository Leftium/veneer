{
	"name": "veneer",
	"private": true,
	"version": "0.0.1",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "prettier --check . && eslint .",
		"knip": "knip"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@leftium/gg": "^0.2.0",
		"@neoconfetti/svelte": "^2.2.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.5.0",
		"@types/store": "^2.0.5",
		"dayjs": "^1.11.20",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"fp-ts": "^2.16.11",
		"globals": "^17.4.0",
		"knip": "^6.1.0",
		"linkifyjs": "^4.3.2",
		"markdown-it": "^14.1.1",
		"markdown-it-center-text": "^1.0.4",
		"markdown-it-easy-tables": "^0.1.1",
		"markdown-it-github-alerts": "^1.0.1",
		"markdown-it-multimd-table": "^4.2.3",
		"markdown-it-sub": "^2.0.0",
		"markdown-it-sup": "^2.0.0",
		"open-props-scss": "^0.8.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sanitize.css": "^13.0.0",
		"sass-embedded": "^1.98.0",
		"store": "^2.0.12",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.5",
		"svelte-confetti": "^2.3.2",
		"swiper": "^12.1.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2",
		"web-sentinel": "^0.1.5",
		"wellcrafted": "^0.34.1"
	},
	"packageManager": "pnpm@10.11.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@leftium/gg",
			"esbuild"
		]
	},
	"dependencies": {
		"@inlang/paraglide-js": "^2.15.1",
		"markdown-it-deflist": "^3.0.0"
	}
}
